---
import releases from '../../data/releases.json';

// Optional: sort by date descending (most recent first)
const sorted = releases.sort((a, b) => {
  const da = new Date(`${a.date} 2024`); // Month Day, Year fallback
  const db = new Date(`${b.date} 2024`);
  return db - da;
});
---

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
    padding: 1rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    transition: transform 0.15s ease;
  }

  .card:hover {
    transform: translateY(-4px);
  }

  .cover {
    width: 100%;
    height: 260px;
    object-fit: cover;
    background: #eee;
  }

  .info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .title {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .meta {
    font-size: 0.8rem;
    opacity: 0.75;
  }
</style>

<div class="grid">
  {sorted.map((r) => (
    <a href={r.link} class="card" target="_blank">
      <img
        class="cover"
        src={r.cover ?? '/covers/placeholder.jpg'}
        alt={r.title}
        loading="lazy"
      />

      <div class="info">
        <div class="title">{r.title}</div>
        <div class="meta">Vol. {r.volume}</div>
        <div class="meta">{r.publisher}</div>
        <div class="meta">{r.date}</div>
      </div>
    </a>
  ))}
</div>


