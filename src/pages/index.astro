---
import releases from '../data/releases.json';
---

<html>
  <head>
    <title>LN Releases</title>
    <style>
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
        padding: 1rem;
      }
      .item {
        width: 100%;
        height: 220px;
        background: #eee;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <h1 style="text-align:center;">Upcoming Light Novel Releases</h1>
    <div class="grid">
      {releases.map(() => (
        <div class="item"></div>
      ))}
    </div>
  </body>
</html>
